{
  "buildCommand": "npm install --prefix web/frontend && npm run build --prefix web/frontend",
  "outputDirectory": "web/frontend/dist",
  "functions": {
    "api/index.py": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
