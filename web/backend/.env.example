# Supabase credentials for the shared custom-item library (Item Library tab).
# Copy this file to `.env` and fill in your project's values.
#
# Find these in the Supabase dashboard: Project Settings → API.
#   SUPABASE_URL  — the Project URL, e.g. https://abcdefgh.supabase.co
#   SUPABASE_KEY  — an API key. The backend talks to PostgREST server-side, so
#                   a service_role key works and bypasses RLS. If you prefer the
#                   anon key, add a permissive RLS policy on `custom_items`.
SUPABASE_URL=
SUPABASE_KEY=

# --- Dropbox (Texture Pack tab) -------------------------------------------
# Create a "scoped access / full Dropbox" app at
# https://www.dropbox.com/developers/apps and grant these scopes:
#   files.content.write, files.content.read, files.metadata.read,
#   sharing.write, sharing.read
# NOTE: scopes are baked into the token when you authorize. If you enable a
# scope AFTER generating the token, you must re-run the token script.
# App key + secret come from the app's Settings page. Get the refresh token by
# running:  python scripts/dropbox_get_refresh_token.py
# Set all three in Vercel's Environment Variables for the deployed backend too.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# Optional overrides (defaults shown):
# DROPBOX_UNZIPPED_DIR=/Unzipped Texture Pack
# DROPBOX_ZIPPED_PATH=/Zipped Texture Pack/pack.zip

